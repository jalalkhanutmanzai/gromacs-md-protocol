# ─────────────────────────────────────────────────────────────────────────────
# config/config.env.example
#
# Copy this file to config/config.env and edit the values.
# config/config.env is gitignored so your local paths never get committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── GROMACS binary ────────────────────────────────────────────────────────────
# Path to the gmx executable.  Leave as "gmx" if it is in your PATH.
# For a conda install: /path/to/miniforge3/envs/gmx2024/bin/gmx
# For an Apptainer run, see INSTALLATION.md.
GMX_BIN=gmx

# ── CPU / threading ───────────────────────────────────────────────────────────
# Number of OpenMP threads per MPI rank.
# Set to the number of physical CPU cores on your node (not hyperthreads).
NTOMP=4

# Number of MPI ranks (thread-MPI).  Set to 1 for a single GPU.
NTMPI=1

# ── GPU ───────────────────────────────────────────────────────────────────────
# Comma-separated GPU device IDs to use.  Usually "0" for a single GPU.
GPU_ID=0

# ── Force field and water model ───────────────────────────────────────────────
# Force field name as recognised by gmx pdb2gmx.
FF_NAME=charmm36-jul2022

# Water model name as recognised by gmx pdb2gmx.
WATER_MODEL=tip3p

# ── Box parameters ────────────────────────────────────────────────────────────
# Minimum distance (nm) from solute to box edge.
BOX_DISTANCE=1.0

# Box type: triclinic | cubic | dodecahedron | octahedron
BOX_TYPE=dodecahedron

# ── Ion / salt parameters ─────────────────────────────────────────────────────
# Salt concentration (mol/L) added after neutralisation.
SALT_CONC=0.15

# Positive ion name (must match GROMACS residue name)
ION_POS=NA

# Negative ion name
ION_NEG=CL

# ── Reproducibility ───────────────────────────────────────────────────────────
# Random seed for velocity generation in NVT.
# Use a fixed integer for reproducible runs (e.g. 1234).
# Use -1 to let GROMACS choose a random seed each time.
GEN_SEED=1234

# ── Input paths ───────────────────────────────────────────────────────────────
# Directory containing user-supplied input files (gitignored by pattern)
INPUT_DIR=input

# Filename of the cleaned protein PDB (relative to INPUT_DIR)
PROTEIN_PDB=protein_clean.pdb

# Directory containing CHARMM-GUI/CGenFF ligand files (relative to INPUT_DIR)
LIGAND_DIR=charmm_ligand

# Ligand ITP file name inside LIGAND_DIR
LIGAND_ITP=lig.itp

# Ligand coordinate file (PDB format) inside LIGAND_DIR
LIGAND_PDB=lig_ini.pdb

# Molecule name as it appears in the [ moleculetype ] section of LIGAND_ITP
LIGAND_MOLNAME=LIG

# ── Output paths ──────────────────────────────────────────────────────────────
# Working directory for step outputs (gitignored)
WORK_DIR=work

# Directory for analysis results (gitignored)
RESULTS_DIR=results

# ── MDP files ─────────────────────────────────────────────────────────────────
MDP_DIR=mdp
MDP_EM=em.mdp
MDP_NVT=nvt.mdp
MDP_NPT=npt.mdp
MDP_MD=md_100ns.mdp
